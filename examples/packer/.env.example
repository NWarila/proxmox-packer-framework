# ============================================================================================= #
# .env.example — Environment variables for Proxmox authentication                              #
#                                                                                               #
# Copy this file to .env and update the values for your environment.                            #
# These variables are consumed by Packer (PKR_VAR_*).                                           #
# ============================================================================================= #

# --- Proxmox Settings ---------------------------------------------------------------------- #
PKR_VAR_proxmox_hostname="10.69.128.49"
PKR_VAR_proxmox_api_token_id="packer@pam!packer_pve_token"
PKR_VAR_proxmox_api_token_secret="AAaAAAaA0aaAaaAAAAaAaAaA0AaaaAaaA0aA0aa00a00a0aaAAAaAA0aaaAaAA"
PKR_VAR_proxmox_skip_tls_verify="true"
PKR_VAR_proxmox_node="tcnhq-prxmx01"

# --- Deploy User --------------------------------------------------------------------------- #
PKR_VAR_deploy_user_name="builder"
PKR_VAR_deploy_user_password="AAaAAAaA0aaAaaAAAAaAaAaA0AaaaAaaA0aA0aa00a00a0aaAAAaAA0aaaAaAA"
PKR_VAR_deploy_user_public_key="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMockExampleKeyOnly builder@example"
