# Ignore everything by default
**

# --- Root ---
!.gitignore
!.gitattributes
!.editorconfig
!.pre-commit.config.yaml
!.release-please-manifest.json
!release-please-config.json
!CHANGELOG.md
!CODE_OF_CONDUCT.md
!CONTRIBUTING.md
!LICENSE
!README.md
!SECURITY.md
!SUPPORT.md

# --- .config ---
!.config/
!.config/.markdownlint.json
!.config/.yamllint.yaml

# --- .github ---
!.github/
!.github/.gitkeep
!.github/CODEOWNERS
!.github/FUNDING.yml
!.github/dependabot.yml
!.github/pull_request_template.md
!.github/actions/
!.github/actions/.gitkeep
!.github/config/
!.github/config/gitleaks.toml
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/bug_report.yml
!.github/ISSUE_TEMPLATE/feature_request.yml
!.github/ISSUE_TEMPLATE/config.yml
!.github/scripts/
!.github/scripts/get_packer_version.sh
!.github/scripts/validate_examples.sh
!.github/scripts/validate_examples.ps1
!.github/scripts/validate_terraform.sh
!.github/scripts/validate_terraform.ps1
!.github/workflows/
!.github/workflows/.gitkeep
!.github/workflows/main-validation.yml
!.github/workflows/feature-push-gate.yml
!.github/workflows/pr-validation.yaml
!.github/workflows/release-please.yaml
!.github/workflows/security.yaml

# --- .vscode ---
!.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json

# --- docs ---
!docs/
!docs/architecture.md
!docs/template-contract.md

# --- examples ---
!examples/
!examples/packer/
!examples/packer/.env.example
!examples/packer/rocky-linux-9/
!examples/packer/rocky-linux-9/ks.pkrtpl.hcl
!examples/packer/rocky-linux-9/rocky-linux-9.pkrvars.hcl
!examples/packer/ubuntu-24-04/
!examples/packer/ubuntu-24-04/ubuntu-24-04-lts.pkrvars.hcl
!examples/packer/ubuntu-24-04/user-data.pkrtpl.hcl
!examples/packer/windows-server-2022/
!examples/packer/windows-server-2022/autounattend.pkrtpl.hcl
!examples/packer/windows-server-2022/windows-server-2022.pkrvars.hcl
!examples/terraform/
!examples/terraform/.env.example
!examples/terraform/terraform.tfvars.example

# --- packer ---
!packer/
!packer/.gitkeep
!packer/builds.pkr.hcl
!packer/data.pkr.hcl
!packer/locals.pkr.hcl
!packer/packer.pkr.hcl
!packer/source.pkr.hcl
!packer/variables.pkr.hcl

# --- packer/iso ---
!packer/iso/
!packer/iso/catalog.json
!packer/iso/rocky-linux-9.pkrvars.hcl
!packer/iso/ubuntu-24-04-lts.pkrvars.hcl
!packer/iso/windows-server-2022.pkrvars.hcl

# --- packer/artifacts, manifests (keep dir, not contents) ---
!packer/artifacts/
!packer/artifacts/.gitkeep
!packer/manifests/
!packer/manifests/.gitkeep

# --- terraform ---
!terraform/
!terraform/data.tf
!terraform/locals.tf
!terraform/.terraform.lock.hcl
!terraform/outputs.tf
!terraform/providers.tf
!terraform/resources.tf
!terraform/variables.tf
!terraform/versions.tf
